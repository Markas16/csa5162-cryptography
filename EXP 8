#include <stdio.h>
#include <string.h>
#include <ctype.h>

int main()
{
    char plain[100], cipher[100];
    char key[]="CIPHERABDFGJKLMNOQSTUVWXYZ";

    printf("Enter Plaintext (CAPS): ");
    scanf("%s",plain);

    for(int i=0; plain[i]; i++)
    {
        if(isalpha(plain[i]))
            cipher[i]=key[plain[i]-'A'];
        else
            cipher[i]=plain[i];
    }

    cipher[strlen(plain)]='\0';

    printf("Ciphertext: %s\n",cipher);

    return 0;
}
